{
    "$schema": "https://aka.ms/sppnp-extract-configuration-schema",
    "handlers": [
        "Lists",
        "WebSettings",
        "Pages",
        "SiteSecurity",
        "Navigation",
        "SiteSettings"
    ],
    "persistAssetFiles": true,
    "siteSecurity": {
        "includeSiteGroups": true
    },
    "pages": {
        "excludeAuthorInformation": false,
        "includeAllClientSidePages": true
    },
    "navigation": {
        "removeExistingNodes": true
    },
    "lists": {
        "lists": [
            {
                "title": "Boveda",
                "includeItems": false
            },
            {
                "title": "Aprobadores",
                "includeItems": false
            },
            {
                "title": "CondicionesDocumento",
                "includeItems": true,
                "skipEmptyFields": true,
                "query": {
                    "camlQuery": "<Order><FieldRef Name='ID' /></Order>",
                    "includeAttachments": false,
                    "viewFields": [
					    "Title",
                        "Activo"				  
                    ]
                }
            },
            {
                "title": "ConfiguracionRecurrencia",
                "includeItems": true,
                "skipEmptyFields": true,
